# Actidea CRM — Variables de entorno
# Copia este archivo a .env y llena los valores

# Token de integración de Notion (ntn_xxxx o secret_xxxx)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs de las bases de datos de Notion (32 caracteres hexadecimales)
# Para obtener el ID: abre la DB en Notion, copia la URL y toma los 32 chars después de notion.so/
NOTION_DB_PROSPECTOS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_CLIENTES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_OPS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_COTIZACIONES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_PAGOS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_PROVEEDORES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_DEUDAS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_CASOS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_TICKETS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_USUARIOS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_OBJETIVOS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_AUDITORIA=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Panel de Seguridad (interruptor de emergencia para revocar todo el acceso)
NOTION_DB_SEGURIDAD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta para firmar los tokens de sesión (JWT).
# OBLIGATORIA en producción. Genera una con: openssl rand -hex 32
JWT_SECRET=

# Email para envío de respaldos automáticos mensuales y reset de contraseñas
# Obtén tu key gratis en https://resend.com
RESEND_API_KEY=
BACKUP_EMAIL_TO=

# API Key de Anthropic (para Vision AI en documentos de clientes)
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# URL pública del CRM (para los enlaces de los correos de reset de contraseña)
APP_URL=https://actidea-os.up.railway.app

# Orígenes permitidos por CORS, separados por coma. OBLIGATORIO en producción.
ALLOWED_ORIGIN=https://actidea-os.up.railway.app

# Puerto del servidor (opcional, default: 3000)
PORT=3000
