{
  "name": "actidea-crm",
  "version": "1.0.0",
  "description": "Actidea CRM — Sistema interno de gestión comercial y operativa",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest",
    "test:ci": "jest --ci --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:secrets": "node tests/helpers/check-secrets.js",
    "test:all": "npm run test:ci && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@notionhq/client": "^2.2.15",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "jest": "^30.4.2",
    "playwright": "^1.61.1",
    "supertest": "^7.2.2"
  }
}
